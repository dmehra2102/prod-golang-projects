# ── Application ───────────────────────────────────────────────────────────────
APP_ENV=development
APP_VERSION=dev

# ── gRPC Server Ports ─────────────────────────────────────────────────────────
INGESTION_GRPC_PORT=50051
QUERY_GRPC_PORT=50052

# ── Metrics ───────────────────────────────────────────────────────────────────
METRICS_PORT=9090
METRICS_PATH=/metrics

# ── PostgreSQL ────────────────────────────────────────────────────────────────
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_USER=fleet
POSTGRES_PASSWORD=fleet_secret
POSTGRES_DB=fleet_telemetry
POSTGRES_DSN=postgres://fleet:fleet_secret@localhost:5432/fleet_telemetry?sslmode=disable
POSTGRES_MAX_CONNS=25
POSTGRES_MIN_CONNS=5
POSTGRES_MAX_CONN_LIFETIME=30m
POSTGRES_MAX_CONN_IDLE_TIME=10m
POSTGRES_HEALTH_CHECK_PERIOD=1m

# ── Kafka ─────────────────────────────────────────────────────────────────────
KAFKA_BROKERS=localhost:9092
KAFKA_TOPIC_TELEMETRY=fleet.telemetry.raw
KAFKA_TOPIC_DLQ=fleet.telemetry.dlq
KAFKA_CONSUMER_GROUP=fleet-processor
KAFKA_CLIENT_ID=fleet-telemetry-hub
KAFKA_PRODUCER_RETRY_MAX=5
KAFKA_PRODUCER_RETRY_BACKOFF_MS=100
KAFKA_PRODUCER_REQUIRED_ACKS=all
KAFKA_CONSUMER_FETCH_MIN=1
KAFKA_CONSUMER_FETCH_MAX=10485760
KAFKA_TLS_ENABLED=false
KAFKA_SASL_ENABLED=false
KAFKA_SASL_MECHANISM=PLAIN
KAFKA_SASL_USERNAME=
KAFKA_SASL_PASSWORD=

# ── JWT Auth ──────────────────────────────────────────────────────────────────
JWT_SECRET=changeme_replace_with_min_32_char_secret_in_production
JWT_ISSUER=fleet-telemetry-hub
JWT_EXPIRY_HOURS=24

# ── Processor ─────────────────────────────────────────────────────────────────
PROCESSOR_BATCH_SIZE=100
PROCESSOR_FLUSH_INTERVAL_MS=500
PROCESSOR_WORKER_COUNT=4
PROCESSOR_CHANNEL_BUFFER=1000

# ── Logging ───────────────────────────────────────────────────────────────────
LOG_LEVEL=info
LOG_FORMAT=json